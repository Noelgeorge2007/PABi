\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Distribution of PABI values for 100 FDA-approved drugs stratified by administration route: oral (blue, $n = 55$), injectable (red, $n = 25$), and CNS agents (green, $n = 20$). Dashed lines indicate empirical PABI range boundaries: oral $\in [0.35, 0.55]$, injectable $\in [0.45, 0.65]$, CNS $\in [0.25, 0.45]$. These ranges reflect the distinct polar--aromatic balance requirements for each route and may serve as guidelines for lead optimization.\relax }}{25}{figure.caption.21}\protected@file@percent }
\newlabel{fig:drug_distribution}{{7}{25}{Distribution of PABI values for 100 FDA-approved drugs stratified by administration route: oral (blue, $n = 55$), injectable (red, $n = 25$), and CNS agents (green, $n = 20$). Dashed lines indicate empirical PABI range boundaries: oral $\in [0.35, 0.55]$, injectable $\in [0.45, 0.65]$, CNS $\in [0.25, 0.45]$. These ranges reflect the distinct polar--aromatic balance requirements for each route and may serve as guidelines for lead optimization.\relax }{figure.caption.21}{}}
