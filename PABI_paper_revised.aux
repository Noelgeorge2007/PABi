\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Scatter plots of PABI versus (a) melting point, (b) boiling point, and (c) LogP for the training set ($n = 200$). Blue circles represent individual compounds. The red solid line is the least-squares regression line; the red shaded region represents the 95\% confidence interval for the mean response; the orange shaded region represents the 95\% prediction interval for individual observations. All correlations are statistically significant at $p < 0.001$ (F-test). The close agreement between $R^2$ and leave-one-out $Q^2_{\text  {LOO}}$ (differences $\leq 0.012$) confirms minimal overfitting.\relax }}{17}{figure.caption.9}\protected@file@percent }
\newlabel{fig:scatter_plots}{{4}{17}{Scatter plots of PABI versus (a) melting point, (b) boiling point, and (c) LogP for the training set ($n = 200$). Blue circles represent individual compounds. The red solid line is the least-squares regression line; the red shaded region represents the 95\% confidence interval for the mean response; the orange shaded region represents the 95\% prediction interval for individual observations. All correlations are statistically significant at $p < 0.001$ (F-test). The close agreement between $R^2$ and leave-one-out $Q^2_{\text {LOO}}$ (differences $\leq 0.012$) confirms minimal overfitting.\relax }{figure.caption.9}{}}
