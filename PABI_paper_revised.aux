\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Average $R^2$ across three target properties (MP, BP, LogP) as a function of the PABI scaling exponent $\alpha $, varied from 0.50 to 1.00 in steps of 0.05. The optimal value $\alpha = 0.75$ (red dashed line) maximizes average $R^2 = 0.794$. The shaded region $\alpha \in [0.70, 0.80]$ shows where $R^2$ varies by $<2\%$, demonstrating robustness. The optimal $\alpha $ lies between surface-area normalization ($\alpha = 2/3$) and volume normalization ($\alpha = 1$).\relax }}{5}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:alpha_optim}{{1}{5}{Average $R^2$ across three target properties (MP, BP, LogP) as a function of the PABI scaling exponent $\alpha $, varied from 0.50 to 1.00 in steps of 0.05. The optimal value $\alpha = 0.75$ (red dashed line) maximizes average $R^2 = 0.794$. The shaded region $\alpha \in [0.70, 0.80]$ shows where $R^2$ varies by $<2\%$, demonstrating robustness. The optimal $\alpha $ lies between surface-area normalization ($\alpha = 2/3$) and volume normalization ($\alpha = 1$).\relax }{figure.caption.1}{}}
